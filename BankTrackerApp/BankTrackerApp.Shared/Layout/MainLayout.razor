@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <div class="page">
            <NavMenu />
        <main>
            <TopBar />

            <article class="content px-4">
                <MudMainContent Style="height: calc(100vh - var(--mud-appbar-height)); padding: 0;">
                    @Body
                </MudMainContent>
            </article>
        </main>
    </div>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>