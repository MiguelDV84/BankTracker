@page "/"
@using BankTrackerApp.Shared.Components.CardContent
@using BankTrackerApp.Shared.Components.Balance
@using BankTrackerApp.Shared.Pages.Historico

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
        <MudGrid Spacing="4" Style="height: calc(100vh - var(--mud-appbar-height))">
            <MudItem xs="12" sm="6">
                <MudPaper Class="d-flex flex-column" Elevation="2" Style="height: 100%;">
                    <Balance />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Class="d-flex justify-center" Elevation="2" Style="height: 100%; min-height: 200px;">
                    <Historico _onPagerContent="true" _onSearcher="false" _rowsPerPage="5" />
                </MudPaper>
            </MudItem>
        </MudGrid>
</MudContainer>