@page "/"
@using BankTrackerApp.Shared.CardContent

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    @if (_isLoading)
    {
        <div class="d-flex justify-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_cuenta != null)
    {
        <CardContent Titulo="@_cuenta.NumeroCuenta" 
                     Cuerpo="@($"{_cuenta.Saldo:N2} €")" 
                     TextoBoton="Ver Movimientos" />
    }
    else
    {
        <MudAlert Severity="Severity.Error">@(_errorMessage ?? "No se pudieron cargar los datos")</MudAlert>
    }
</MudContainer>