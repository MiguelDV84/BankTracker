@page "/estadistica"

<MudContainer MaxWidth="MaxWidth.False" Gutters="false">
    <MudText Typo="Typo.h4" Class="mb-4">Análisis de Gastos e Ingresos</MudText>

    <MudPaper Class="pa-4" Elevation="0">
        <MudChart ChartType="ChartType.Bar"
                  ChartSeries="@_series"
                  @bind-SelectedIndex="_index"
                  ChartLabels="@_xAxisLabels"
                  ChartOptions="_axisChartOptions"
                  Width="100%"
                  Height="@($"{_height}px")"
                  MatchBoundsToSize="@_matchBoundsToSize">
        </MudChart>
    </MudPaper>
</MudContainer>