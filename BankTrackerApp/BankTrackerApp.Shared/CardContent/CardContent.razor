<MudCard Outlined="true" Class="rounded-lg pa-4">
    <MudCardContent>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="text-uppercase">
            @Titulo
        </MudText>
        <MudText Typo="Typo.h4" Class="mud-text-primary font-weight-bold">
            @Cuerpo
        </MudText>
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" DisableElevation="true">
            @TextoBoton
        </MudButton>
    </MudCardActions>
</MudCard>